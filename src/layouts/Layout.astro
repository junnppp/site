---
import Head from "@components/Head.astro";
import Sidebar from "@components/Sidebar.astro";
import Lightbox from "@components/Lightbox.astro";
import { SITE } from "@consts";

type Props = {
  title: string;
  description: string;
};

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="ko">
  <head>
    <Head title={`${title} | ${SITE.TITLE}`} description={description} />
  </head>
  <body>
    <noscript>
      <style>
        .animate{
          opacity:1;
          translate: var(--tw-translate-x) calc(var(--spacing) * 0);
        }
      </style>
    </noscript>
    <div
      class="mx-auto grid w-full max-w-[880px] grid-cols-1 gap-x-14 gap-y-10 px-6 py-10 sm:grid-cols-[200px_1fr] sm:py-16"
    >
      <Sidebar />
      <main class="min-w-0 pb-16">
        <slot />
      </main>
    </div>
    <Lightbox />
  </body>
</html>
