---
import Layout from "@layouts/Layout.astro";
import { SITE } from "@consts";
---

<Layout title="404" description={SITE.DESCRIPTION}>
  <h1 class="animate text-lg font-bold tracking-tight text-ink">
    404 — 페이지를 찾을 수 없습니다
  </h1>
  <p class="animate mt-2 text-sm text-sub">
    주소가 바뀌었거나 삭제된 페이지입니다.
  </p>
  <a
    href="/"
    class="animate mt-6 inline-block text-sm text-sub underline decoration-white/25 underline-offset-[3px] transition-colors duration-300 hover:text-ink hover:decoration-accent"
  >
    홈으로 돌아가기
  </a>
</Layout>
