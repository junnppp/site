---
import Layout from "@layouts/Layout.astro";
import { HOME } from "@consts";

const certificates = [
  {
    name: "Applied Data Science with Python",
    href: "https://www.coursera.org/account/accomplishments/specialization/certificate/ZSGWV9ENWW59",
  },
  {
    name: "Learn SQL Basics for Data Science",
    href: "https://www.coursera.org/account/accomplishments/specialization/certificate/GZ8AQARFLSVE",
  },
  {
    name: "Data Visualization with Tableau",
    href: "https://www.coursera.org/account/accomplishments/specialization/certificate/UJ4JZG8HW2DM",
  },
];
---

<Layout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <h1 class="animate text-lg font-bold tracking-tight text-ink">이력서</h1>
  <p class="animate mt-2 mb-11 max-w-[48ch] text-[0.95rem] text-sub">
    게임 데이터로 마케팅·사업 의사결정을 돕는 데이터 분석가입니다. SQL ·
    Python · BigQuery로 분석하고, 검증된 수치 근거로 빠른 답보다 맞는 답을
    찾는 데 집중합니다.
  </p>

  <section class="animate mb-10">
    <h2 class="mb-2 text-xs font-semibold uppercase tracking-[0.14em] text-sub">
      Skills
    </h2>
    <p class="text-[0.95rem]">SQL · Python · Excel · Tableau · BigQuery · Notion</p>
  </section>

  <section class="animate mb-10">
    <h2 class="mb-2 text-xs font-semibold uppercase tracking-[0.14em] text-sub">
      Experience
    </h2>
    <div class="border-t border-line py-3.5">
      <div class="flex items-baseline justify-between gap-4">
        <b class="text-[0.95rem] font-semibold text-ink">
          조이시티 (Joycity) — Data Analyst
        </b>
        <span class="shrink-0 text-xs text-sub tabular-nums">2023.09 — 현재</span>
      </div>
      <ul class="mt-2 flex list-disc flex-col gap-1 pl-4 text-sm">
        <li>매출 시뮬레이션 기반 사업성 검토 · 월별 Sales KPI 설정 및 트래킹</li>
        <li>ROAS KPI 설계, 매체 운영 고도화 (Meta · Google · Ad Network)</li>
        <li>대규모 업데이트 효과 분석, Business Model 사업성 검토</li>
      </ul>
    </div>
    <div class="border-t border-line py-3.5">
      <div class="flex items-baseline justify-between gap-4">
        <b class="text-[0.95rem] font-semibold text-ink">
          스패로우 (Sparrow) — Digital Marketing Intern
        </b>
        <span class="shrink-0 text-xs text-sub tabular-nums">
          2021.06 — 2021.08
        </span>
      </div>
      <p class="mt-1 text-sm text-sub">
        세미나 참가자 데이터 분석으로 타겟 성향 도출, 콘텐츠 제작
      </p>
    </div>
    <div class="border-y border-line py-3.5">
      <div class="flex items-baseline justify-between gap-4">
        <b class="text-[0.95rem] font-semibold text-ink">
          삐에아떼르 (pied à terre) — Digital Marketing Intern
        </b>
        <span class="shrink-0 text-xs text-sub tabular-nums">
          2020.12 — 2021.06
        </span>
      </div>
      <p class="mt-1 text-sm text-sub">
        네이버 애널리틱스 기반 세그먼트별 콘텐츠로 데일리 방문자 약 200명 유치
      </p>
    </div>
  </section>

  <section class="animate mb-10">
    <h2 class="mb-2 text-xs font-semibold uppercase tracking-[0.14em] text-sub">
      Education
    </h2>
    <div class="border-y border-line py-3.5">
      <div class="flex items-baseline justify-between gap-4">
        <b class="text-[0.95rem] font-semibold text-ink">
          위스콘신 대학교 (University of Wisconsin–Madison)
        </b>
        <span class="shrink-0 text-xs text-sub tabular-nums">
          2017.08 — 2023.05
        </span>
      </div>
      <p class="mt-1 text-sm text-sub">
        통계학 · 데이터 과학 복수 전공 · GPA 3.87/4.00
      </p>
    </div>
  </section>

  <section class="animate">
    <h2 class="mb-2 text-xs font-semibold uppercase tracking-[0.14em] text-sub">
      Certificates
    </h2>
    <p class="text-sm">
      Coursera 2022 —
      {
        certificates.map((cert, i) => (
          <>
            <a
              href={cert.href}
              target="_blank"
              class="text-soft underline decoration-white/25 underline-offset-[3px] transition-colors duration-300 hover:text-ink hover:decoration-accent"
            >
              {cert.name}
            </a>
            {i < certificates.length - 1 && " · "}
          </>
        ))
      }
    </p>
  </section>
</Layout>
