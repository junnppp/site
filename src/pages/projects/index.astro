---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import { PROJECTS } from "@consts";

const projects = (await getCollection("projects"))
  .filter((project) => !project.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const defaultGhost = projects.find((p) => p.data.ghost)?.data.ghost ?? "";
---

<Layout title={PROJECTS.TITLE} description={PROJECTS.DESCRIPTION}>
  <p class="animate mb-10 max-w-[46ch] text-[0.95rem] text-sub">
    게임 데이터로 마케팅·사업 의사결정을 돕습니다. 검증된 수치 근거로, 빠른
    답보다 <b class="font-medium text-ink">맞는 답</b>을 찾습니다.
  </p>

  <div class="animate flex flex-col">
    {
      projects.map((project) => (
        <a
          href={`/projects/${project.id}`}
          class="case-block group relative block border-t border-line py-5 last:border-b"
          data-ghost={project.data.ghost}
        >
          <span class="mb-1 block text-[0.72rem] font-medium uppercase tracking-[0.07em] text-accent tabular-nums">
            {project.data.result}
          </span>
          <h3 class="mb-1 text-[1.06rem] font-semibold leading-normal tracking-tight text-ink">
            {project.data.title}
          </h3>
          <p class="max-w-[48ch] text-sm text-sub">{project.data.description}</p>
        </a>
      ))
    }
  </div>

  <h2
    class="animate mt-12 mb-1 text-xs font-semibold uppercase tracking-[0.14em] text-sub"
  >
    Experience
  </h2>
  <div
    class="animate flex items-baseline justify-between gap-4 border-t border-line py-3 text-[0.9rem]"
  >
    <b class="font-semibold text-ink">조이시티 · Data Analyst</b>
    <span class="shrink-0 text-xs text-sub tabular-nums">2023 — 현재</span>
  </div>
  <div
    class="animate flex items-baseline justify-between gap-4 border-y border-line py-3 text-[0.9rem]"
  >
    <b class="font-semibold text-ink">위스콘신 대학교 · 통계학/데이터과학</b>
    <span class="shrink-0 text-xs text-sub tabular-nums">2017 — 2023</span>
  </div>

  <div
    id="ghost"
    aria-hidden="true"
    class="pointer-events-none fixed right-[4vw] bottom-[8%] hidden text-[clamp(4rem,14vw,9rem)] leading-none font-extrabold tracking-tighter whitespace-nowrap text-white/[0.04] transition-opacity duration-300 tabular-nums sm:block"
  >
    {defaultGhost}
  </div>
</Layout>

<style>
  .case-block {
    transition: padding-left 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .case-block::before {
    content: "";
    position: absolute;
    left: 0;
    top: 20px;
    bottom: 20px;
    width: 2px;
    background: var(--color-accent);
    transform: scaleY(0);
    transform-origin: top;
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .case-block:hover {
    padding-left: 14px;
  }
  .case-block:hover::before {
    transform: scaleY(1);
  }
  @media (prefers-reduced-motion: reduce) {
    .case-block,
    .case-block::before {
      transition: none;
    }
  }
</style>

<script>
  function initGhost() {
    const ghost = document.getElementById("ghost");
    if (!ghost) return;
    document.querySelectorAll<HTMLElement>(".case-block").forEach((block) => {
      block.addEventListener("mouseenter", () => {
        const metric = block.dataset.ghost;
        if (!metric) return;
        ghost.style.opacity = "0";
        setTimeout(() => {
          ghost.textContent = metric;
          ghost.style.opacity = "1";
        }, 160);
      });
    });
  }
  initGhost();
  document.addEventListener("astro:page-load", initGhost);
</script>
