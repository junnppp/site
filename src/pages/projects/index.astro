---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import { PROJECTS } from "@consts";

const projects = (await getCollection("projects"))
  .filter((project) => !project.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title={PROJECTS.TITLE} description={PROJECTS.DESCRIPTION}>
  <Container>
    <div class="space-y-16">
      <section class="space-y-3">
        <h1 class="animate font-semibold text-black dark:text-white">
          포트폴리오
        </h1>
        <p class="animate max-w-prose">
          조이시티 마케팅 데이터 분석 대표 사례입니다. 각 사례는 문제 — 가설 —
          분석 — 결과의 구조로 정리했습니다.
        </p>
      </section>
      <section class="animate">
        <ul class="not-prose flex flex-col">
          {
            projects.map((project) => (
              <li class="border-t border-black/10 last:border-b dark:border-white/15">
                <a
                  href={`/projects/${project.id}`}
                  class="group flex items-baseline justify-between gap-6 py-4"
                >
                  <span>
                    <span class="block font-medium text-black/80 transition-colors duration-300 ease-in-out group-hover:text-black dark:text-white/80 dark:group-hover:text-white">
                      {project.data.title}
                    </span>
                    <span class="block max-w-prose text-sm text-black/50 dark:text-white/50">
                      {project.data.description}
                    </span>
                  </span>
                  <span class="shrink-0 text-sm text-black/50 tabular-nums dark:text-white/50">
                    {project.data.result}
                  </span>
                </a>
              </li>
            ))
          }
        </ul>
      </section>
    </div>
  </Container>
</Layout>
